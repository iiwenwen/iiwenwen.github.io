---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="关于" description="关于本站">
  <article class="post">
    <a class="back-link" href={import.meta.env.BASE_URL}>返回首页</a>
    <header class="post-header">
      <h1>关于</h1>
    </header>
    <div class="prose">
      <p>欢迎来到我的个人博客。</p>
      <p>这里记录我的思考、阅读笔记和生活片段，使用 Markdown 编写，通过 Astro 生成静态页面。</p>
    </div>
  </article>
</BaseLayout>
