---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter((post) => import.meta.env.DEV || !post.data.draft);
  const columns = new Set<string>();
  for (const post of posts) {
    for (const col of post.data.categories) columns.add(col);
  }
  return [...columns].map((col) => ({ params: { column: col } }));
}

const { column } = Astro.params;
const baseUrl = import.meta.env.BASE_URL;

const columnPosts = (await getCollection("blog"))
  .filter((post) => import.meta.env.DEV || !post.data.draft)
  .filter((post) => post.data.categories.includes(column))
  .sort((a, b) => {
    const aDate = a.data.pubDate ?? a.data.date ?? new Date(0);
    const bDate = b.data.pubDate ?? b.data.date ?? new Date(0);
    return bDate.valueOf() - aDate.valueOf();
  });
---

<BaseLayout title={`${column}`} description={`${column} 专栏`}>
  <article class="post">
    <nav class="breadcrumb">
      <a href={baseUrl}>首页</a>
      <span>/</span>
      <a href={`${baseUrl}columns/`}>专栏</a>
      <span>/</span>
      <span>{column}</span>
    </nav>
    <header class="post-header">
      <h1>{column}</h1>
    </header>
    <ul class="archive-list">
      {columnPosts.map((post) => (
        <li>
          <a href={`${baseUrl}blog/${post.slug}/`}>
            <time datetime={(post.data.pubDate ?? post.data.date)?.toISOString()}>
              {(post.data.pubDate ?? post.data.date)?.toLocaleDateString("zh-CN")}
            </time>
            <span>{post.data.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </article>
</BaseLayout>
