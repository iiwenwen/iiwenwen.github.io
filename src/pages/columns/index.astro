---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog"))
  .filter((post) => import.meta.env.DEV || !post.data.draft);

const columnMap = new Map<string, typeof posts>();
for (const post of posts) {
  for (const col of post.data.categories) {
    if (!columnMap.has(col)) columnMap.set(col, []);
    columnMap.get(col)!.push(post);
  }
}

const columns = [...columnMap.entries()].sort((a, b) => b[1].length - a[1].length);
const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout title="专栏" description={`共 ${columns.length} 个专栏`}>
  <article class="post">
    <header class="post-header">
      <h1>专栏</h1>
    </header>
    {columns.length === 0 ? (
      <p>暂无专栏。</p>
    ) : (
      <ul class="archive-list">
        {columns.map(([col, colPosts]) => (
          <li>
            <a href={`${baseUrl}columns/${col}/`}>
              <span>{col}</span>
              <time>{colPosts.length} 篇</time>
            </a>
          </li>
        ))}
      </ul>
    )}
  </article>
</BaseLayout>
