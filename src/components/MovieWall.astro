---
interface MovieItem {
  title: string;
  director?: string;
  cover?: string;
  date?: string;
  runningTime?: string;
  rating?: number;
  summary?: string;
  remark?: string;
  tags?: string[];
  url?: string;
  zotero_key?: string;
  slug?: string;
}

const { items, baseUrl, maxInitial = 24 } = Astro.props as {
  items: MovieItem[];
  baseUrl: string;
  maxInitial?: number;
};

const visible = items.slice(0, maxInitial);
const hidden = items.slice(maxInitial);
---

<svg aria-hidden="true" style="display: none;">
  <symbol id="icon-star-filled" viewBox="0 0 24 24">
    <path fill="currentColor" d="M10.788 3.102c.495-1.003 1.926-1.003 2.421 0l2.358 4.778l5.273.766c1.107.16 1.549 1.522.748 2.303l-3.816 3.719l.901 5.25c.19 1.104-.968 1.945-1.959 1.424l-4.716-2.48l-4.715 2.48c-.99.52-2.148-.32-1.96-1.423l.901-5.251l-3.815-3.72c-.801-.78-.359-2.141.748-2.302L8.43 7.88z"/>
  </symbol>
  <symbol id="icon-star-empty" viewBox="0 0 24 24">
    <path fill="none" stroke="currentColor" stroke-width="1.5" d="M10.788 3.102c.495-1.003 1.926-1.003 2.421 0l2.358 4.778l5.273.766c1.107.16 1.549 1.522.748 2.303l-3.816 3.719l.901 5.25c.19 1.104-.968 1.945-1.959 1.424l-4.716-2.48l-4.715 2.48c-.99.52-2.148-.32-1.96-1.423l.901-5.251l-3.815-3.72c-.801-.78-.359-2.141.748-2.302L8.43 7.88z"/>
  </symbol>
</svg>

<div class="ticket-layout" id="ticket-layout">
  {visible.map((item, index) => {
    const rating = Math.min(5, Math.max(0, Math.round(item.rating ?? 0)));
    const displayDate = item.date
      ? new Date(item.date).toLocaleDateString("zh-CN", { year: "numeric", month: "2-digit", day: "2-digit" })
      : "";
    const isCurrentYear = item.date ? new Date(item.date).getFullYear() === new Date().getFullYear() : false;
    const dateStr = isCurrentYear ? displayDate.slice(5) : displayDate;

    return (
      <div class="ticket-item">
        <div class="ticket-body">
          <div class="rc-comment">
            {item.remark || item.summary?.slice(0, 80) || "静静欣赏，沉浸其中..."}
          </div>
        </div>
        <div class="ticket-stub">
          <div class="rc-meta">
            <div class="rc-title">
              {item.url ? (
                <a href={item.url} target="_blank" rel="noopener">{item.title}</a>
              ) : item.slug ? (
                <a href={`${baseUrl}blog/${item.slug}/`}>{item.title}</a>
              ) : (
                <span>{item.title}</span>
              )}
            </div>
            <div class="rc-stars">
              {Array.from({ length: 5 }, (_, i) => (
                <svg class={i < rating ? "star-filled" : "star-empty"}>
                  <use href={i < rating ? "#icon-star-filled" : "#icon-star-empty"}></use>
                </svg>
              ))}
            </div>
          </div>
          <div class="ticket-footer">
            <div class="rc-time"><time>{dateStr}</time></div>
            {item.zotero_key && <div class="rc-barcode">ID:{item.zotero_key}</div>}
          </div>
        </div>
      </div>
    );
  })}
</div>

{hidden.length > 0 && (
  <button id="btn-load-more" class="ticket-btn-more">看更多...</button>
)}

<script type="application/json" id="ticket-data" data-bast={baseUrl}>
  {JSON.stringify(hidden)}
</script>

<script>
  (function () {
    const btn = document.getElementById("btn-load-more");
    const layout = document.getElementById("ticket-layout");
    const dataScript = document.getElementById("ticket-data");
    if (!btn || !layout || !dataScript) return;

    const baseUrl = dataScript.dataset.bast || "/";
    let remaining = JSON.parse(dataScript.textContent || "[]");
    const BATCH = 12;

    function buildCard(item) {
      const rating = Math.min(5, Math.max(0, Math.round(item.rating ?? 0)));
      const date = item.date ? new Date(item.date) : null;
      const displayDate = date
        ? date.toLocaleDateString("zh-CN", { year: "numeric", month: "2-digit", day: "2-digit" })
        : "";
      const now = new Date();
      const isCurrentYear = date && date.getFullYear() === now.getFullYear();
      const dateStr = isCurrentYear ? displayDate.slice(5) : displayDate;
      const titleHtml = item.url
        ? `<a href="${item.url}" target="_blank" rel="noopener">${item.title}</a>`
        : item.slug
          ? `<a href="${baseUrl}blog/${item.slug}/">${item.title}</a>`
          : `<span>${item.title}</span>`;

      const stars = Array.from({ length: 5 }, (_, i) =>
        `<svg class="${i < rating ? "star-filled" : "star-empty"}"><use href="${i < rating ? "#icon-star-filled" : "#icon-star-empty"}"></use></svg>`
      ).join("");

      const div = document.createElement("div");
      div.className = "ticket-item";
      div.innerHTML = `<div class="ticket-body"><div class="rc-comment">${item.remark || (item.summary || "").slice(0, 80) || "静静欣赏，沉浸其中..."}</div></div>
        <div class="ticket-stub">
          <div class="rc-meta"><div class="rc-title">${titleHtml}</div><div class="rc-stars">${stars}</div></div>
          <div class="ticket-footer"><div class="rc-time"><time>${dateStr}</time></div>${item.zotero_key ? `<div class="rc-barcode">ID:${item.zotero_key}</div>` : ""}</div>
        </div>`;
      return div;
    }

    btn.addEventListener("click", () => {
      const batch = remaining.slice(0, BATCH);
      remaining = remaining.slice(BATCH);
      const fragment = document.createDocumentFragment();
      batch.forEach((item) => fragment.appendChild(buildCard(item)));
      layout.appendChild(fragment);
      if (remaining.length === 0) btn.remove();
    });
  })();
</script>
