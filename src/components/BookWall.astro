---
interface BookItem {
  title: string;
  author: string;
  cover: string;
  date: string;
  rating: number;
  summary: string;
  slug: string;
}

const { items, baseUrl } = Astro.props as { items: BookItem[]; baseUrl: string };
---

<div class="media-wall">
  {items.map((item) => (
    <div class="media-card">
      <div class="media-cover">
        {item.cover ? (
          <img src={item.cover} alt={item.title} loading="lazy" />
        ) : (
          <div class="media-cover-placeholder">
            <span>{item.title.slice(0, 2)}</span>
          </div>
        )}
      </div>
      <div class="media-info">
        <h3>
          {item.slug ? (
            <a href={`${baseUrl}blog/${item.slug}/`}>{item.title}</a>
          ) : (
            item.title
          )}
        </h3>
        <p class="media-meta">{item.author}</p>
        {item.date && !isNaN(new Date(item.date).valueOf()) && (
          <time datetime={item.date}>
            {new Date(item.date).toLocaleDateString("zh-CN")}
          </time>
        )}
        <div class="media-rating">
          {"★".repeat(item.rating)}{"☆".repeat(5 - item.rating)}
        </div>
              </div>
    </div>
  ))}
</div>
