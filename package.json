{
  "name": "newblog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "npm run zotero:sync && ASTRO_TELEMETRY_DISABLED=1 astro build && npx pagefind --site dist && cp -r dist/pagefind public/pagefind",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "check": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "zotero:sync": "python3 scripts/convert_zotero.py --fetch",
    "douban:sync": "python3 scripts/sync_douban.py",
    "sync": "npm run douban:sync && npm run zotero:sync"
  },
  "dependencies": {
    "astro": "^5.0.0",
    "lxgw-wenkai-webfont": "^1.7.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "pagefind": "^1.5.2",
    "typescript": "^5.8.0"
  }
}
